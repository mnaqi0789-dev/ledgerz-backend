generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  maker
  manager
  admin
}

enum EntryType {
  in
  out
  treasury_transfer
}

enum EntryCategory {
  rent
  salaries
  client_payment
  treasury
  misc
}

enum EntryStatus {
  submitted
  approved
  rejected
}

enum TreasuryAction {
  buy
  sell
}

enum AuditRefType {
  entry
  treasury
  objection
}

model User {
  id                   Int                   @id @default(autoincrement())
  name                 String
  email                String                @unique
  passwordHash         String                @map("password_hash")
  role                 UserRole
  createdAt            DateTime              @default(now()) @map("created_at")
  submittedEntries     Entry[]               @relation("EntrySubmittedBy")
  decidedEntries       Entry[]               @relation("EntryDecidedBy")
  executedTransactions TreasuryTransaction[] @relation("TransactionExecutedBy")
  raisedObjections     Objection[]           @relation("ObjectionRaisedBy")
  auditLogs            AuditLog[]            @relation("AuditActor")

  @@map("users")
}

model Entry {
  id              Int           @id @default(autoincrement())
  amount          Decimal
  type            EntryType
  category        EntryCategory
  description     String
  status          EntryStatus   @default(submitted)
  submittedBy     Int           @map("submitted_by")
  submitter       User          @relation("EntrySubmittedBy", fields: [submittedBy], references: [id])
  decidedBy       Int?          @map("decided_by")
  decider         User?         @relation("EntryDecidedBy", fields: [decidedBy], references: [id])
  rejectionReason String?       @map("rejection_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  decidedAt       DateTime?     @map("decided_at")
  objections      Objection[]

  @@map("entries")
}

model TreasuryHolding {
  id              Int                   @id @default(autoincrement())
  assetName       String                @unique @map("asset_name")
  quantity        Decimal
  buyPrice        Decimal               @map("buy_price")
  currentPrice    Decimal               @map("current_price")
  lastPriceUpdate DateTime              @map("last_price_update")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  transactions    TreasuryTransaction[]

  @@map("treasury_holdings")
}

model TreasuryTransaction {
  id         Int             @id @default(autoincrement())
  holdingId  Int             @map("holding_id")
  holding    TreasuryHolding @relation(fields: [holdingId], references: [id])
  action     TreasuryAction
  quantity   Decimal
  price      Decimal
  executedBy Int             @map("executed_by")
  executor   User            @relation("TransactionExecutedBy", fields: [executedBy], references: [id])
  createdAt  DateTime        @default(now()) @map("created_at")

  @@map("treasury_transactions")
}

model Objection {
  id        Int      @id @default(autoincrement())
  entryId   Int      @map("entry_id")
  entry     Entry    @relation(fields: [entryId], references: [id])
  raisedBy  Int      @map("raised_by")
  raiser    User     @relation("ObjectionRaisedBy", fields: [raisedBy], references: [id])
  note      String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("objections")
}

model AuditLog {
  id        Int          @id @default(autoincrement())
  refType   AuditRefType @map("ref_type")
  refId     Int          @map("ref_id")
  action    String
  actorId   Int          @map("actor_id")
  actor     User         @relation("AuditActor", fields: [actorId], references: [id])
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("audit_log")
}